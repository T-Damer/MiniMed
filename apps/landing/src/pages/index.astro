---
import '../styles/global.css';

// biome-ignore lint/correctness/noUnusedVariables: Astro consumes this value in the template.
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com';

// biome-ignore lint/correctness/noUnusedVariables: Astro consumes this value in the template.
const milestones = [
  {
    version: '0.1',
    state: 'закрыто',
    title: 'Локальный фонд',
    copy: 'Скомпилированный SQLite pack, FTS5, BM25, стабильные якоря и исходный контекст.',
  },
  {
    version: '0.2',
    state: 'закрыто',
    title: 'Клиническая карточка',
    copy: 'Длинный свободный ввод, извлечение измеримых фактов и несколько поисковых веток.',
  },
  {
    version: '0.3',
    state: 'текущая alpha',
    title: 'Семантический слой',
    copy: 'Переносимый vector-профиль, FTS5 + vector fusion, диагностика и lexical fallback.',
  },
  {
    version: '0.4',
    state: 'позже',
    title: 'Облачное усиление',
    copy: 'Необязательный BYOK-синтез только по материалам, уже найденным локальным ядром.',
  },
];

// biome-ignore lint/correctness/noUnusedVariables: Astro consumes this value in the template.
const principles = [
  [
    '01',
    'Источник остаётся источником',
    'Система открывает конкретный раздел и абзац, а не скрывает литературу за ответом модели.',
  ],
  [
    '02',
    'Сеть не является зависимостью',
    'Поиск, структура документов и чтение фонда доступны полностью на устройстве.',
  ],
  [
    '03',
    'Интеллект добавляется слоями',
    'Сначала точный retrieval, затем embeddings и только после этого — необязательная генерация.',
  ],
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="LocalMed Search — локальная медицинская картотека с быстрым поиском по выбранному корпусу документов."
    />
    <meta name="theme-color" content="#48453f" />
    <title>LocalMed Search — локальная медицинская картотека</title>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <header class="archive-nav">
      <a class="brand" href="#top" aria-label="LocalMed Search — к началу страницы">
        <span class="brand-mark">LM</span>
        <span class="brand-title">
          <small>Локальная медицинская</small>
          <strong>Картотека</strong>
        </span>
      </a>
      <nav aria-label="Навигация по странице">
        <a href="#dossier">Досье</a>
        <a href="#method">Метод</a>
        <a href="#roadmap">Опись работ</a>
        <a class="repo-link" href={githubUrl}>GitHub ↗</a>
      </nav>
      <div class="nav-register">
        <small>ФОНД</small>
        <strong>2026 / 002</strong>
      </div>
    </header>

    <main id="top">
      <section class="hero-folder">
        <div class="folder-tab">ДЕЛО № 002 · LOCALMED SEARCH</div>
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="kicker">Offline-first · retrieval before generation</p>
            <h1>Медицинская литература, открытая сразу на нужном месте.</h1>
            <p class="lead">
              Свободно опишите случай. Локальное ядро выделит факты, построит несколько поисковых
              веток и покажет исходный раздел — без сервера и без обязательного ответа нейросети.
            </p>
            <div class="hero-actions">
              <a class="primary-action" href="#dossier">Открыть досье</a>
              <a class="text-action" href={githubUrl}>Исходный код ↗</a>
            </div>
          </div>

          <aside class="case-card" aria-label="Пример работы поиска">
            <span class="paper-clip" aria-hidden="true"></span>
            <div class="card-header">
              <span>КАРТОЧКА ЗАПРОСА</span>
              <b>LOCAL / 0.3 α</b>
            </div>
            <p class="case-query">
              Мальчик 5 лет, второй день температура до 39 °C, часто дышит, кашля нет.
            </p>
            <dl class="fact-ledger">
              <div><dt>возраст</dt><dd>5 лет</dd></div>
              <div><dt>t°</dt><dd>39 °C</dd></div>
              <div><dt>срок</dt><dd>2 дня</dd></div>
              <div class="negative"><dt>отрицается</dt><dd>кашель</dd></div>
            </dl>
            <div class="found-slip">
              <span>НАЙДЕННЫЙ ЛИСТ</span>
              <strong>Внебольничная пневмония → Клиническая картина</strong>
              <p>…лихорадка и тахипноэ могут быть ведущими признаками у ребёнка…</p>
              <small>исходный абзац / соседний контекст →</small>
            </div>
            <span class="offline-stamp">OFFLINE<br />READY</span>
          </aside>
        </div>

        <div class="hero-register" aria-label="Ключевые свойства">
          <div><span>ХРАНИЛИЩЕ</span><strong>SQLite / FTS5 + vector</strong></div>
          <div><span>ВВОД</span><strong>Свободный текст</strong></div>
          <div><span>ВЫХОД</span><strong>Раздел + anchor</strong></div>
          <div><span>СЕТЬ</span><strong>Не требуется</strong></div>
        </div>
      </section>

      <section id="dossier" class="dossier-section">
        <aside class="section-index">
          <span>01</span>
          <p>ДОСЬЕ ПРОЕКТА</p>
        </aside>
        <div class="section-body">
          <p class="kicker">Назначение</p>
          <h2>Не медицинский чат. Поисковый инструмент по выбранному фонду.</h2>
          <div class="dossier-grid">
            <article class="memo-sheet">
              <span class="memo-number">A–01</span>
              <h3>Проблема</h3>
              <p>
                Точный термин, торговое название, симптом или критерий могут быть распределены по
                десяткам документов. Обычный поиск возвращает страницу; врачу нужен конкретный лист.
              </p>
            </article>
            <article class="memo-sheet">
              <span class="memo-number">A–02</span>
              <h3>Решение</h3>
              <p>
                Документы заранее превращаются в локальный content pack со структурой, полнотекстовым
                индексом и стабильными точками перехода.
              </p>
            </article>
            <article class="memo-sheet">
              <span class="memo-number">A–03</span>
              <h3>Граница</h3>
              <p>
                Версия 0.3 alpha ищет и объясняет, почему материал найден. Она не сочиняет медицинский ответ
                и не зависит от облачной модели.
              </p>
            </article>
          </div>
        </div>
      </section>

      <section id="method" class="method-folder">
        <div class="folder-tab dark-tab">МЕТОД / ПОИСКОВОЕ ПРОИЗВОДСТВО</div>
        <div class="method-heading">
          <p class="kicker">От рассказа к первоисточнику</p>
          <h2>Длинный запрос не сжимается в одну догадку.</h2>
          <p>
            Ядро сохраняет исходный текст и параллельно строит отдельные ветки для клинических
            терминов, измерений, обследований и препаратов. Результаты объединяются прозрачно.
          </p>
        </div>
        <ol class="process-ledger">
          <li>
            <span>01</span>
            <div><small>ПРИЁМ</small><strong>Свободное описание</strong></div>
            <p>До 20 000 знаков, без обязательной анкеты перед поиском.</p>
          </li>
          <li>
            <span>02</span>
            <div><small>КАРТОЧКА</small><strong>Детерминированные факты</strong></div>
            <p>Возраст, пол, сроки, температура, измерения и отрицания.</p>
          </li>
          <li>
            <span>03</span>
            <div><small>РАЗВЕТВЛЕНИЕ</small><strong>Несколько запросов</strong></div>
            <p>Исходная, клиническая, инструментальная и лекарственная ветки.</p>
          </li>
          <li>
            <span>04</span>
            <div><small>ВЫДАЧА</small><strong>Hybrid fusion</strong></div>
            <p>FTS5/BM25 и локальные vector-кандидаты объединяются без генеративного шага.</p>
          </li>
          <li>
            <span>05</span>
            <div><small>ЧТЕНИЕ</small><strong>Исходный лист</strong></div>
            <p>Раздел, найденный абзац, соседний контекст и техническая карточка.</p>
          </li>
        </ol>
      </section>

      <section class="principles-section">
        <div class="section-heading-inline">
          <p class="kicker">Правила фонда</p>
          <h2>Три ограничения, которые делают продукт надёжнее.</h2>
        </div>
        <div class="principle-cards">
          {principles.map(([number, title, copy]) => (
            <article>
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </section>

      <section id="roadmap" class="roadmap-section">
        <aside class="section-index light-index">
          <span>02</span>
          <p>ОПИСЬ РАБОТ</p>
        </aside>
        <div class="roadmap-sheet">
          <header>
            <div>
              <p class="kicker">Версии фонда</p>
              <h2>Сначала полезный поиск. Затем интеллект поверх него.</h2>
            </div>
            <span class="review-stamp">ПЛАН<br />ПРИНЯТ</span>
          </header>
          <div class="roadmap-table">
            {milestones.map((item) => (
              <article class:list={{ current: item.version === '0.3' }}>
                <span class="roadmap-version">{item.version}</span>
                <span class="roadmap-state">{item.state}</span>
                <div>
                  <h3>{item.title}</h3>
                  <p>{item.copy}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="repository-card">
        <div>
          <p class="kicker">Открытый журнал разработки</p>
          <h2>Рабочее ядро уже собирает SQLite-фонд и выполняет поиск локально.</h2>
        </div>
        <a href={githubUrl}>Перейти в репозиторий <span>↗</span></a>
      </section>
    </main>

    <footer>
      <span>LOCALMED SEARCH / PERSONAL ENGINEERING PROTOTYPE</span>
      <span>Fixture corpus не является медицинской рекомендацией</span>
      <span>BUILD 0.3.0-alpha.1 / 2026</span>
    </footer>
  </body>
</html>
