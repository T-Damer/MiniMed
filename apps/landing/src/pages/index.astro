---
import '../styles/global.css';

// biome-ignore lint/correctness/noUnusedVariables: Astro consumes this value in the template.
const githubUrl = import.meta.env.PUBLIC_GITHUB_URL ?? 'https://github.com/T-Damer/MiniMed';

// biome-ignore lint/correctness/noUnusedVariables: Astro consumes this value in the template.
const milestones = [
  {
    version: '0.1',
    state: 'закрыто',
    title: 'Локальный фонд',
    copy: 'Скомпилированный SQLite pack, FTS5, BM25, стабильные якоря и исходный контекст.',
  },
  {
    version: '0.2',
    state: 'закрыто',
    title: 'Клиническая карточка',
    copy: 'Длинный свободный ввод, извлечение измеримых фактов и несколько поисковых веток.',
  },
  {
    version: '0.3',
    state: 'текущая alpha',
    title: 'Семантический слой',
    copy: 'Переносимый vector-профиль, FTS5 + vector fusion, диагностика и lexical fallback.',
  },
  {
    version: '0.4',
    state: 'позже',
    title: 'Облачное усиление',
    copy: 'Необязательный BYOK-синтез только по материалам, уже найденным локальным ядром.',
  },
];

// biome-ignore lint/correctness/noUnusedVariables: Astro consumes this value in the template.
const principles = [
  [
    '01',
    'Источник остаётся источником',
    'Система открывает конкретный раздел и абзац, а не скрывает литературу за ответом модели.',
  ],
  [
    '02',
    'Сеть не является зависимостью',
    'Поиск, структура документов и чтение фонда доступны полностью на устройстве.',
  ],
  [
    '03',
    'Интеллект добавляется слоями',
    'Сначала точный retrieval, затем embeddings и только после этого — необязательная генерация.',
  ],
];
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta
      name="description"
      content="MiniMed — локальная медицинская картотека с быстрым поиском по выбранному корпусу документов."
    />
    <meta name="theme-color" content="#48453f" />
    <link rel="icon" type="image/svg+xml" href="./favicon.svg" />
    <title>MiniMed — локальная медицинская картотека</title>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <header class="archive-nav">
      <a class="brand" href="#top" aria-label="MiniMed — к началу страницы">
        <img class="brand-mark brand-mark-image" src="./favicon.svg" alt="" width="42" height="42" />
        <span class="brand-title">
          <small>Локальная медицинская</small>
          <strong>Картотека</strong>
        </span>
      </a>
      <nav aria-label="Навигация по странице">
        <a href="#dossier">Досье</a>
        <a href="#method">Метод</a>
        <a href="#roadmap">Опись работ</a>
        <a class="repo-link" href={githubUrl}>GitHub ↗</a>
      </nav>
      <div class="nav-register">
        <small>ФОНД</small>
        <strong>2026 / 003</strong>
      </div>
    </header>

    <main id="top">
      <section class="hero-folder">
        <div class="folder-tab">ДЕЛО № 003 · MINIMED</div>
        <div class="hero-grid">
          <div class="hero-copy">
            <p class="kicker">Offline-first · retrieval before generation</p>
            <h1>Медицинская литература, открытая сразу на нужном месте.</h1>
            <p class="lead">
              Свободно опишите случай. Локальное ядро выделит факты, построит несколько поисковых
              веток и покажет исходный раздел — без сервера и без обязательного ответа нейросети.
            </p>
            <div class="hero-actions">
              <a class="primary-action" href="#dossier">Открыть досье</a>
              <a class="text-action" href={githubUrl}>Исходный код ↗</a>
            </div>
          </div>

          <aside class="case-card" aria-label="Пример работы поиска">
            <span class="paper-clip" aria-hidden="true"></span>
            <div class="card-header">
              <span>КАРТОЧКА ЗАПРОСА</span>
              <b>LOCAL / 0.3 α</b>
            </div>
            <p class="case-query">
              Мальчик 5 лет, второй день температура до 39 °C, часто дышит, кашля нет.
            </p>
            <dl class="fact-ledger">
              <div><dt>возраст</dt><dd>5 лет</dd></div>
              <div><dt>t°</dt><dd>39 °C</dd></div>
              <div><dt>срок</dt><dd>2 дня</dd></div>
              <div class="negative"><dt>отрицается</dt><dd>кашель</dd></div>
            </dl>
            <div class="result-slip">
              <small>НАЙДЕННЫЙ РАЗДЕЛ</small>
              <strong>Пневмония / Диагностика</strong>
              <p>…тахипноэ и локальные физикальные признаки требуют оценки…</p>
            </div>
          </aside>
        </div>
      </section>

      <section class="dossier-section" id="dossier">
        <div class="section-register">
          <span>ДОСЬЕ / 01</span>
          <strong>Что уже работает</strong>
        </div>
        <div class="dossier-grid">
          <article><span>01</span><h2>Свободный ввод</h2><p>До 20 000 символов клинического описания без обязательной анкеты.</p></article>
          <article><span>02</span><h2>Локальный индекс</h2><p>SQLite FTS5 и предрассчитанные векторы находятся вместе с корпусом.</p></article>
          <article><span>03</span><h2>Точный источник</h2><p>Результат ведёт к разделу, абзацу, соседнему контексту и стабильному якорю.</p></article>
          <article><span>04</span><h2>Без обязательного сервера</h2><p>Поиск и чтение продолжают работать в самолётном режиме.</p></article>
        </div>
      </section>

      <section class="method-section" id="method">
        <div class="method-sheet">
          <span class="paper-clip" aria-hidden="true"></span>
          <div class="section-register dark-register">
            <span>МЕТОД / 02</span>
            <strong>Как устроен поиск</strong>
          </div>
          <ol>
            <li><span>01</span><div><strong>Сохранить исходный рассказ</strong><p>Описание не заменяется скрытым резюме.</p></div></li>
            <li><span>02</span><div><strong>Выделить факты и отрицания</strong><p>Возраст, длительность, показатели, препараты и отсутствующие признаки остаются проверяемыми.</p></div></li>
            <li><span>03</span><div><strong>Построить несколько веток</strong><p>Точный термин, исходная формулировка, обследования и терапия ищутся независимо.</p></div></li>
            <li><span>04</span><div><strong>Объединить FTS5 и vector evidence</strong><p>Точное совпадение не теряется из-за смыслового ранжирования.</p></div></li>
          </ol>
        </div>
        <aside class="principle-stack">
          {principles.map(([number, title, copy]) => (
            <article>
              <span>{number}</span><h3>{title}</h3><p>{copy}</p>
            </article>
          ))}
        </aside>
      </section>

      <section class="roadmap-section" id="roadmap">
        <div class="section-register">
          <span>ОПИСЬ / 03</span>
          <strong>Версии и границы</strong>
        </div>
        <div class="roadmap-table">
          {milestones.map((milestone) => (
            <article>
              <span class="version-tab">{milestone.version}</span>
              <div><small>{milestone.state}</small><h2>{milestone.title}</h2><p>{milestone.copy}</p></div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <footer>
      <span>MINIMED / PUBLIC PILOT</span>
      <span>Справочно-поисковая система · не заменяет решение врача</span>
      <a href={githubUrl}>Репозиторий ↗</a>
    </footer>
  </body>
</html>
