# The deterministic search path does not require secrets or a model.
VITE_ENABLE_EXPERIMENTAL_CLOUD=false

# Mutable model metadata catalog. The bundled catalog remains the offline and invalid-remote fallback.
VITE_LOCAL_MODEL_CATALOG_URL=https://raw.githubusercontent.com/T-Damer/MiniMed/main/apps/app/src/features/models/catalog.preview.json

# MiniMed-owned checksum-verified GitHub Release mirror. This is the default for public builds so the
# app does not depend on model hosts that may be blocked on the user's network.
VITE_LOCAL_MODEL_ASSET_BASE_URL=https://github.com/T-Damer/MiniMed/releases/download/models-preview-1
VITE_LOCAL_MODEL_ALLOW_UPSTREAM=false
VITE_LOCAL_MODEL_AUTOLOAD=true
# Keep false outside the dedicated scheduled model-smoke workflow.
VITE_LOCAL_MODEL_ALLOW_AUTOMATION_DOWNLOADS=false

# Used by the static landing outside GitHub Pages. Pages CI sets it automatically.
PUBLIC_GITHUB_URL=https://github.com/OWNER/REPOSITORY
