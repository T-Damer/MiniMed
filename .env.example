# The deterministic search path does not require secrets or a model.
VITE_ENABLE_EXPERIMENTAL_CLOUD=false

# Mutable model metadata/artifact catalog. Executable runtime URLs remain pinned by the bundled app;
# keep the bundled catalog as an offline, invalid-remote, and cache fallback.
VITE_LOCAL_MODEL_CATALOG_URL=https://raw.githubusercontent.com/T-Damer/MiniMed/main/apps/app/src/features/models/catalog.preview.json

# Immutable GitHub Release asset directory, for example:
# https://github.com/T-Damer/MiniMed/releases/download/models-2026.07
# Leave blank during development to use the verified upstream artifact URLs in the catalog.
VITE_LOCAL_MODEL_ASSET_BASE_URL=
VITE_LOCAL_MODEL_ALLOW_UPSTREAM=true
VITE_LOCAL_MODEL_WEBGPU=true
VITE_LOCAL_MODEL_AUTOLOAD=true

# Used by the static landing outside GitHub Pages. Pages CI sets it automatically.
PUBLIC_GITHUB_URL=https://github.com/OWNER/REPOSITORY
